# ===========================================
# DATABASE (PostgreSQL)
# ===========================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=crypto_db
DB_USER=postgres
DB_PASSWORD=secure_password_123

# ===========================================
# REDIS (Celery Broker & Backend)
# ===========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ===========================================
# APPLICATION SETTINGS
# ===========================================
APP_NAME=Crypto Price Tracker
APP_DEBUG=true
APP_LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8000

# ===========================================
# DERIBIT API
# ===========================================
DERIBIT_BASE_URL=https://test.deribit.com
DERIBIT_REQUEST_TIMEOUT=30

# ===========================================
# CELERY SETTINGS
# ===========================================
CELERY_TIMEZONE=UTC
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT='["json"]'
CELERY_FETCH_PRICE_INTERVAL=60